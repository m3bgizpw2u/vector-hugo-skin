# Hugo build artifacts (workspace root and any nested location, since `hugo --source`
# can emit to <source>/public/ depending on flags).
**/public/
**/resources/
.hugo_build.lock

# Node tooling (dev-time only)
node_modules/
npm-debug.log*

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Vendored upstream source (Vector skin at SHA 7c224883, REL1_42 — see
# vendor/mediawiki-vector/PROVENANCE.md). Tracked in-tree per phase 1 of
# the third plan; the upstream's own .git is stripped before commit.
# Do NOT add `/vendor/` here — the tree is intentionally tracked.
/vendor/mediawiki-vector/.git/

# Planning notes (read-only research material, lives inside workspace for convenience
# but is never part of the theme repo's history).
/.plans/

# Editor/OS noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

.cursor/plans/